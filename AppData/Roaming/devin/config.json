{
  "version": 1,
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp", "--api-key", "${env:CONTEXT7_API_KEY}"]
    },
    "heroui-react": {
      "command": "npx",
      "args": ["-y", "@heroui/react-mcp@latest"]
    },
    "heroui-native": {
      "command": "npx",
      "args": ["-y", "@heroui/native-mcp@latest"]
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp"
    }
  },
  "shell": {
    "setup_complete": true
  },
  "theme_mode": "dark",
  "read_config_from": {
    "cursor": false,
    "windsurf": false,
    "claude": false
  }
}
