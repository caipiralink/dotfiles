{
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "bun \"${CURSOR_PLUGIN_ROOT}/dist/session-start.js\"",
        "timeout": 20
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "command": "bun \"${CURSOR_PLUGIN_ROOT}/dist/session-end.js\"",
        "timeout": 30
      }
    ]
  }
}
