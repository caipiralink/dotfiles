{{ if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = 'Stop'

$repoUrl = 'https://github.com/caipiralink/awesome-codex-subagents.git'
$destDir = Join-Path (Join-Path $HOME '.codex') 'agents'
$manifest = Join-Path $destDir '.awesome-codex-subagents.manifest'
$revision = Join-Path $destDir '.awesome-codex-subagents.revision'

New-Item -ItemType Directory -Path $destDir -Force | Out-Null

$remoteHeadLine = git ls-remote $repoUrl HEAD
if ($LASTEXITCODE -ne 0) {
    throw "git ls-remote failed for: $repoUrl"
}
$remoteHead = (($remoteHeadLine | Select-Object -First 1) -split '\s+')[0]
if (-not $remoteHead) {
    throw "Could not determine remote HEAD for: $repoUrl"
}

$shouldSync = $true
if ((Test-Path $revision) -and (Test-Path $manifest) -and ((Get-Item -LiteralPath $manifest).Length -gt 0)) {
    $currentHead = Get-Content -LiteralPath $revision -TotalCount 1
    if ($currentHead -and ($currentHead.Trim() -eq $remoteHead)) {
        $missingFile = $false
        foreach ($name in Get-Content -LiteralPath $manifest) {
            if (-not $name) {
                continue
            }

            if (-not (Test-Path -LiteralPath (Join-Path $destDir $name))) {
                $missingFile = $true
                break
            }
        }

        $shouldSync = $missingFile
    }
}

if (-not $shouldSync) {
    return
}

$sha256 = [System.Security.Cryptography.SHA256]::Create()
try {
    $hashBytes = $sha256.ComputeHash([System.Text.Encoding]::UTF8.GetBytes($repoUrl))
} finally {
    $sha256.Dispose()
}
$repoHash = (-join ($hashBytes | ForEach-Object { $_.ToString('x2') })).Substring(0, 12)
$repoDir = Join-Path ([System.IO.Path]::GetTempPath()) "codex-agents-$repoHash-$([System.Guid]::NewGuid().ToString('N'))"
$sourceRoot = Join-Path $repoDir 'categories'

try {
    git clone --depth 1 $repoUrl $repoDir
    if ($LASTEXITCODE -ne 0) {
        throw "git clone failed for: $repoUrl"
    }

    if (-not (Test-Path $sourceRoot)) {
        throw "Missing subagent categories directory: $sourceRoot"
    }

    $files = Get-ChildItem -Path $sourceRoot -Recurse -Filter '*.toml' -File
    if (-not $files) {
        throw "No subagent TOML files found in: $sourceRoot"
    }

    $duplicates = $files | Group-Object Name | Where-Object Count -gt 1
    if ($duplicates) {
        $names = ($duplicates | ForEach-Object Name) -join ', '
        throw "Duplicate subagent TOML filenames are not safe to flatten: $names"
    }

    $newNames = $files | Sort-Object Name | ForEach-Object Name

    if (Test-Path $manifest) {
        foreach ($name in Get-Content $manifest) {
            if (-not $name) {
                continue
            }

            if ($newNames -notcontains $name) {
                Remove-Item -LiteralPath (Join-Path $destDir $name) -Force -ErrorAction SilentlyContinue
            }
        }
    }

    foreach ($file in $files) {
        Copy-Item -LiteralPath $file.FullName -Destination (Join-Path $destDir $file.Name) -Force
    }

    $newNames | Set-Content -LiteralPath $manifest -Encoding utf8
    $remoteHead | Set-Content -LiteralPath $revision -Encoding utf8
} finally {
    if (Test-Path $repoDir) {
        Remove-Item -LiteralPath $repoDir -Recurse -Force -ErrorAction SilentlyContinue
    }
}
{{ end -}}
