{{ if eq .chezmoi.os "windows" -}}
# hash: {{ include "private_dot_config/powershell/Microsoft.PowerShell_profile.ps1" | sha256sum }}
$source = Join-Path $env:USERPROFILE ".config" "powershell" "Microsoft.PowerShell_profile.ps1"
$docs   = [Environment]::GetFolderPath('MyDocuments')

if (Test-Path $source) {
    foreach ($dir in @('PowerShell', 'WindowsPowerShell')) {
        $dest = Join-Path $docs $dir "Microsoft.PowerShell_profile.ps1"
        New-Item -ItemType Directory -Path (Split-Path $dest) -Force | Out-Null
        Copy-Item -Path $source -Destination $dest -Force
    }
}
{{ end -}}
