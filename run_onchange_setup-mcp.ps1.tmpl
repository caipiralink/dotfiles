{{ if eq .chezmoi.os "windows" -}}
# hash: {{ .mcp_servers | toJson | sha256sum }}

{{ range $name, $srv := .mcp_servers.stdio -}}
if (Get-Command devin -ErrorAction SilentlyContinue) {
  devin mcp remove -s user '{{ $name }}' 2>$null
  devin mcp add -s user '{{ $name }}' -- '{{ $srv.command }}'{{ range $srv.args }} '{{ . }}'{{ end }}
}
if (Get-Command claude -ErrorAction SilentlyContinue) {
  claude mcp remove '{{ $name }}' --scope user 2>$null
  claude mcp add --scope user '{{ $name }}' -- '{{ $srv.command }}'{{ range $srv.args }} '{{ . | replace "${env:" "${" }}'{{ end }}
}

{{ end -}}
{{ range $name, $srv := .mcp_servers.http -}}
if (Get-Command devin -ErrorAction SilentlyContinue) {
  devin mcp remove -s user '{{ $name }}' 2>$null
  devin mcp add -s user '{{ $name }}' '{{ $srv.url }}'
}
if (Get-Command claude -ErrorAction SilentlyContinue) {
  claude mcp remove '{{ $name }}' --scope user 2>$null
  claude mcp add --scope user --transport http '{{ $name }}' '{{ $srv.url }}'
}

{{ end -}}
{{ end -}}
