{{ if ne .chezmoi.os "windows" -}}
[plugins]
clang-format = "https://github.com/mise-plugins/mise-llvm.git"
clangd = "https://github.com/mise-plugins/mise-llvm.git"
{{ end -}}

[tools]
aws = { version = "latest", symlink_bins = "true" }
{{ if and (eq .chezmoi.os "windows") (eq .chezmoi.arch "arm64") -}}
"github:sharkdp/bat" = { version = "latest", asset_pattern = "bat-*-aarch64-pc-windows-msvc.zip" }
{{- else -}}
bat = "latest"
{{- end }}
{{ if ne .chezmoi.os "windows" -}}
btop = "latest" {{/* TODO: no Windows ARM64 binary available */}}
{{- end }}
{{ if and (eq .chezmoi.os "windows") (eq .chezmoi.arch "arm64") -}}
"github:oven-sh/bun" = { version = "latest", asset_pattern = "bun-windows-aarch64.zip" }
{{- else -}}
bun = "latest"
{{- end }}
chezmoi = "latest"
{{ if and (eq .chezmoi.os "windows") (eq .chezmoi.arch "arm64") -}}
"github:schollz/croc" = { version = "latest", asset_pattern = "croc_*_Windows-ARM64.zip" }
{{- else -}}
croc = "latest"
{{- end }}
deno = "latest"
eza = "latest"
fd = "latest"
fzf = "latest"
gcloud = "latest"
gh = "latest"
git-lfs = "latest"
go = "latest"
helm = "latest"
{{ if and (eq .chezmoi.os "windows") (eq .chezmoi.arch "arm64") -}}
"cargo:hexyl" = "latest"
{{- else -}}
hexyl = "latest"
{{- end }}
java = "zulu-21"
kubectl = "latest"
lazygit = "latest"
neovim = "latest"
node = "lts"
"npm:@anthropic-ai/claude-code" = "latest"
"npm:@openai/codex" = "latest"
"npm:context-mode" = "latest"
"npm:@morphllm/morphmcp" = "latest"
{{ if and (eq .chezmoi.os "windows") (eq .chezmoi.arch "arm64") -}}
"github:anomalyco/opencode" = { version = "latest", asset_pattern = "opencode-windows-arm64.zip" }
{{- else -}}
opencode = "latest"
{{- end }}
{{ if and (eq .chezmoi.os "windows") (eq .chezmoi.arch "arm64") -}}
"cargo:oha" = "latest"
{{- else -}}
oha = "latest"
{{- end }}
python = "3.12"
rclone = "latest"
{{ if and (eq .chezmoi.os "windows") (eq .chezmoi.arch "arm64") -}}
"github:BurntSushi/ripgrep" = { version = "latest", asset_pattern = "ripgrep-*-aarch64-pc-windows-msvc.zip" }
{{- else -}}
ripgrep = "latest"
{{- end }}
rust = "latest"
sccache = "latest"
sing-box = "latest"
starship = "latest"
tmux = "latest"
upx = "latest" {{/* TODO: no Windows ARM64 binary available */}}
{{ if and (eq .chezmoi.os "windows") (eq .chezmoi.arch "arm64") -}}
"github:astral-sh/uv" = { version = "latest", asset_pattern = "uv-aarch64-pc-windows-msvc.zip" }
{{- else -}}
uv = "latest"
{{- end }}
yt-dlp = { version = "latest", rename_exe = "yt-dlp" }
yarn = "latest"
"npm:pnpm" = "latest"
{{ if ne .chezmoi.os "windows" -}}
cmake = "latest"
ninja = "latest"
clang-format = "latest"
clangd = "latest"
{{- end }}
