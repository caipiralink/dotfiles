#!/usr/bin/env bash
set -euo pipefail

CONTAINER_NAME="dev-debian-trixie"
IMAGE="ghcr.io/caipiralink/dotfiles/dev"

resolve_tag() {
  local nvidia=$1
  if [ "$nvidia" = "1" ]; then
    echo "nvidia"
  else
    echo "latest"
  fi
}

cmd_install() {
  local nvidia=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --nvidia) nvidia=1; shift ;;
      *) echo "Unknown flag: $1"; exit 1 ;;
    esac
  done

  local tag
  tag=$(resolve_tag "$nvidia")

  local flags=(
    --image "${IMAGE}:${tag}"
    --name "$CONTAINER_NAME"
    --no-entry
    --pull
  )

  [ "$nvidia" = "1" ] && flags+=(--nvidia)

  distrobox create "${flags[@]}"
  distrobox enter --name "$CONTAINER_NAME" -- distrobox-export --app claude-desktop-ime
  distrobox enter --name "$CONTAINER_NAME" -- distrobox-export --app codex
  distrobox enter --name "$CONTAINER_NAME" -- distrobox-export --app code
  echo "Created '$CONTAINER_NAME' (image tag: $tag)."
}

cmd_remove() {
  distrobox rm --force "$CONTAINER_NAME"
  echo "Removed '$CONTAINER_NAME'."
}

cmd_enter() {
  distrobox enter "$CONTAINER_NAME"
}

cmd_reinstall() {
  local passthrough=("$@")
  cmd_remove 2>/dev/null || true
  cmd_install "${passthrough[@]}"
}

cmd_help() {
  cat <<EOF
Usage: $(basename "$0") <command> [flags]

Commands:
  install [flags]     Create the dev container
  remove              Remove the dev container
  enter               Enter the dev container
  reinstall [flags]   Remove and recreate the dev container
  help                Show this help

Flags (for install/reinstall):
  --nvidia    Enable NVIDIA GPU support

Examples:
  $(basename "$0") install --nvidia
  $(basename "$0") reinstall --nvidia
  $(basename "$0") enter
EOF
}

case "${1:-help}" in
  install)   shift; cmd_install "$@" ;;
  remove)    cmd_remove ;;
  enter)     cmd_enter ;;
  reinstall) shift; cmd_reinstall "$@" ;;
  help|*)    cmd_help ;;
esac
