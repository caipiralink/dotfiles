{{- $shellEnvJSON := "{}" -}}
{{- if not (env "CI") -}}
{{-   $shellEnvJSON = onepasswordRead (printf "%s/shell_env_json" .profile_ref) -}}
{{- end -}}
{{- $shellEnv := mustFromJson $shellEnvJSON -}}
# Generated by chezmoi from 1Password profile shell_env_json.
{{- range $key := keys $shellEnv | sortAlpha }}
{{- $value := index $shellEnv $key -}}
{{- if not (regexMatch "^[A-Za-z_][A-Za-z0-9_]*$" $key) -}}
{{-   fail (printf "invalid shell_env_json key: %s" $key) -}}
{{- end -}}
{{- if not (kindIs "string" $value) -}}
{{-   fail (printf "shell_env_json value for %s must be a string" $key) -}}
{{- end }}
export {{ $key }}='{{ $value | replace "'" "'\\''" }}'
{{- end }}
